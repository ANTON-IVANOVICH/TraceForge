    {
      "type": "timeseries",
      "title": "Fate of ingested points (stored + invalid + failed)",
      "description": "Stacked, these three rates must sum to the ingest rate once the pipeline has drained. A visible gap means points are still in flight.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "sum(rate(traceforge_pipeline_stored_total[5m]))",
