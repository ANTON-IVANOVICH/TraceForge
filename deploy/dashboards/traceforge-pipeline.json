          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "sum(rate(traceforge_pipeline_failed_total[5m]))",
          "range": true,
          "instant": false,
          "refId": "C",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 40,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
