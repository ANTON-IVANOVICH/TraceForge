{
  "uid": "traceforge-overview",
  "title": "TraceForge \u2014 Overview",
  "tags": [
    "traceforge"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "title": "Build version",
      "description": "Instant query with the version label exposed: during a rollout two rows appear at once, which is the fastest way to see a half-finished deploy.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "traceforge_build_info",
          "range": false,
          "instant": true,
          "refId": "A",
          "legendFormat": "{{version}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Goroutines",
      "description": "A monotonic climb here is the classic goroutine leak.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "traceforge_go_goroutines",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Requests in flight",
      "description": "Concurrent HTTP requests being served right now.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "traceforge_http_requests_in_flight",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "stat",
      "title": "Storage series",
      "description": "Distinct series held by the active storage backend.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "traceforge_storage_series",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request rate by status",
      "description": "Per-second HTTP request rate split by response status class.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "sum by (status) (rate(traceforge_http_requests_total[5m]))",
          "range": true,
          "instant": false,
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Error ratio (5xx)",
      "description": "Fraction of requests returning 5xx. clamp_min keeps the ratio well-defined when there is no traffic.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "sum(rate(traceforge_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(traceforge_http_requests_total[5m])), 1)",
          "range": true,
          "instant": false,
          "refId": "A",
          "legendFormat": "5xx share"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Latency p50 / p90 / p99",
      "description": "Percentiles reconstructed from the histogram buckets \u2014 there is no summary quantile to read off directly.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(traceforge_http_request_duration_seconds_bucket[5m])))",
          "range": true,
          "instant": false,
          "refId": "A",
          "legendFormat": "p50 {{route}}"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.90, sum by (le, route) (rate(traceforge_http_request_duration_seconds_bucket[5m])))",
          "range": true,
          "instant": false,
          "refId": "B",
          "legendFormat": "p90 {{route}}"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(traceforge_http_request_duration_seconds_bucket[5m])))",
          "range": true,
          "instant": false,
          "refId": "C",
          "legendFormat": "p99 {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Memory: in use vs limit",
      "description": "The limit series is masked with < 9e18 to hide the math.MaxInt64 sentinel that means 'no limit set' \u2014 otherwise it swamps the axis and hides the real usage line.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "traceforge_go_memory_total_bytes",
          "range": true,
          "instant": false,
          "refId": "A",
          "legendFormat": "in use"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "traceforge_go_memory_limit_bytes < 9e18",
          "range": true,
          "instant": false,
          "refId": "B",
          "legendFormat": "limit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "GC cycle rate",
      "description": "Garbage-collection cycles per second; a spike often precedes a latency bump.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "rate(traceforge_go_gc_cycles_total[5m])",
          "range": true,
          "instant": false,
          "refId": "A",
          "legendFormat": "cycles/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ],
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "stat",
      "title": "GOMAXPROCS",
      "description": "CPUs the runtime will schedule on. A mismatch with the container's CPU quota is a common throttling cause.",
      "datasource": {
        "type": "prometheus",
        "uid": "traceforge-prom"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "traceforge-prom"
          },
          "editorMode": "code",
          "expr": "traceforge_go_maxprocs",
          "range": false,
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    }
  ]
}
